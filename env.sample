API_V1_PREFIX = "/api/v1"

CORS_ORIGINS = ["http://localhost:3000", "http://localhost:5173"]

# 필수 설정
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# DeepAgents 설정
DEEPAGENT_RECURSION_LIMIT=20

# Elasticsearch 설정
ES_URL=https://elasticsearch-edu.didim365.app
ES_USER=elastic
ES_PASSWORD=your_es_password
ES_INDEX_NAME=edu-collection

# 공공 API 키 (식품의약품안전처 e약은요 / 건강보험심사평가원)
MFDS_API_KEY=your_mfds_api_key
HIRA_API_KEY=your_hira_api_key

# Opik (optional)
# OPIK__URL_OVERRIDE=
# OPIK__API_KEY=
# OPIK__WORKSPACE=
# OPIK__PROJECT=