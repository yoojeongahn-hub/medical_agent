                "code_snippet": "WITH perf AS (SELECT employee_name, quarter, AVG(performance_score) AS avg_score FROM employee_performance GROUP BY employee_name, quarter) SELECT employee_name, quarter, avg_score, ROUND((avg_score - LAG(avg_score) OVER(PARTITION BY employee_name ORDER BY quarter)) / LAG(avg_score) OVER(PARTITION BY employee_name ORDER BY quarter) * 100, 2) AS expected_growth FROM perf;"
