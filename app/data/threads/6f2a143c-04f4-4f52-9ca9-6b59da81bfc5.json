                },
                "code_snippet": "SELECT employee_name, COUNT(CASE WHEN status = '정상출근' THEN 1 END) AS normal_days, COUNT(CASE WHEN status = '지각' THEN 1 END) AS late_days FROM attendance WHERE work_date >= DATE_SUB(CURDATE(), INTERVAL 1 MONTH) GROUP BY employee_name ORDER BY late_days DESC;"
